#compdef kb2xb
# zsh completion for kb2xb
# /usr/share/zsh/site-functions/_kb2xb

_kb2xb_profiles() {
    local profile_dir="$HOME/.config/kb2xb/profiles"
    local -a profiles
    if [[ -d "$profile_dir" ]]; then
        profiles=( ${profile_dir}/*.json(N:t:r) )
    fi
    compadd -a profiles
}

_kb2xb_keyboards() {
    local -a devs
    devs=( /dev/input/event*(N) )
    compadd -a devs
}

_kb2xb_profile_cmds() {
    local -a cmds
    cmds=(
        'list:List all profiles'
        'create:Create a new profile'
        'edit:Open profile JSON in $EDITOR'
        'show:Print profile JSON to stdout'
        'delete:Permanently delete a profile'
    )
    _describe 'profile command' cmds
}

_kb2xb() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '(-p --profile)'{-p,--profile}'[Profile ID to load]:profile:_kb2xb_profiles' \
        '(-k --keyboard)'{-k,--keyboard}'[Force a specific keyboard device]:device:_kb2xb_keyboards' \
        '(-v --verbose)'{-v,--verbose}'[Enable debug logging]' \
        '(-V --version)'{-V,--version}'[Print version and exit]' \
        '(-h --help)'{-h,--help}'[Show help]' \
        ':command:->command' \
        '*:: :->args' \
        && return 0

    case $state in
        command)
            local -a commands
            commands=(
                'profile:Manage game profiles'
                'keys:List all valid key names'
                'version:Print version and exit'
            )
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                profile)
                    if (( CURRENT == 2 )); then
                        _kb2xb_profile_cmds
                    else
                        case $words[2] in
                            create)
                                _arguments \
                                    '--clone[Clone keybindings from profile]:profile:_kb2xb_profiles' \
                                    ':name: '
                                ;;
                            edit|show|delete)
                                _kb2xb_profiles
                                ;;
                        esac
                    fi
                    ;;
            esac
            ;;
    esac
}

_kb2xb "$@"
